# ============================================================
# Le Rasa Bakery — Supabase environment
# Copy to .env.local and fill in. .env.local is gitignored.
# ============================================================

# Public — safe to expose to the browser. RLS protects these.
# The anon key is now the "publishable" key (new format: sb_publishable_...).
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<publishable-key>

# Server-only — NEVER prefix with NEXT_PUBLIC_. Bypasses RLS.
# Used only by lib/supabase/server.ts (API routes / server actions).
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Project ref, used by `npm run gen:types`. Just the ref, e.g. hvtjylewfrneoviwzxuk
SUPABASE_PROJECT_REF=<project-ref>
