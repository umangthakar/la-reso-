# ============================================================
# Environment variables — copy to .env.local and fill in.
# .env.local is gitignored. Configure these in Vercel as well.
# ============================================================

# Public — exposed to the browser. Protected by Supabase RLS.
# The anon key is now the "publishable" key (new format: sb_publishable_...).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only — NEVER prefix with NEXT_PUBLIC_. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=

# Optional — key for encrypting admin secrets (e.g. Stripe config).
# Falls back to SUPABASE_SERVICE_ROLE_KEY if unset. Recommended in prod.
ADMIN_ENCRYPTION_KEY=

# Server-only admin gate password. Validated by /api/admin/login; the
# value never reaches the browser. Set a strong password in production.
ADMIN_PASSWORD=

# Optional — Supabase project ref, used only by `npm run gen:types`.
SUPABASE_PROJECT_REF=

# Stripe — customer checkout payments.
# Publishable key is exposed to the browser; secret key is server-only.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
